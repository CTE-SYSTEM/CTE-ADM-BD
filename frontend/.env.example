# Local browser-to-Vite requests can use the Vite proxy.
VITE_API_URL=/api

# Used only by Vite dev server proxy. Docker compose points this to the backend service.
VITE_PROXY_TARGET=http://localhost:5000

# Railway frontend should use the public backend URL.
# VITE_API_URL=https://your-backend.up.railway.app/api
