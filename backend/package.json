{
  "name": "backend",
  "version": "1.0.0",
  "description": "Sistema de Gestión para Centro Técnico Electrónico (CTE)",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test:api": "node --test tests/api/*.test.js",
    "db:generate": "prisma generate",
    "db:sync": "prisma db push --accept-data-loss",
    "studio": "prisma studio --port 5555",
    "db:functions": "psql -v ON_ERROR_STOP=1 \"$SQL_DATABASE_URL\" -f scripts/load_functions.sql",
    "db:auditoria": "psql -v ON_ERROR_STOP=1 \"$SQL_DATABASE_URL\" -f scripts/modules/Auditoria.sql",
    "db:auditoria:ver": "psql -v ON_ERROR_STOP=1 \"$SQL_DATABASE_URL\" -f scripts/auditoria_consultas.sql",
    "db:auditoria:snapshot": "psql -v ON_ERROR_STOP=1 \"$SQL_DATABASE_URL\" -c \"SELECT auditoria_capturar_estado_actual('Snapshot manual') AS registros_auditados;\"",
    "db:deploy": "prisma generate && prisma db push --accept-data-loss && npm run db:functions",
    "db:seed:container": "psql -v ON_ERROR_STOP=1 \"$SQL_DATABASE_URL\" -f scripts/Seed_data.sql",
    "db:seed:operativo": "psql -v ON_ERROR_STOP=1 \"$SQL_DATABASE_URL\" -f scripts/Data_ejemplo.sql",
    "db:functions:container": "psql -v ON_ERROR_STOP=1 \"$SQL_DATABASE_URL\" -f scripts/load_functions.sql",
    "db:check:users": "docker exec postgres_cte psql -U User_admin -d Centro_Tecnico_Electronico -c \"SELECT id_usuario, nombre_usuario, rol, activo FROM \\\"Usuarios\\\" ORDER BY id_usuario;\"",
    "db:check:clientes": "docker exec postgres_cte psql -U User_admin -d Centro_Tecnico_Electronico -c \"SELECT * FROM \\\"Clientes\\\";\"",
    "db:check:tecnicos": "docker exec postgres_cte psql -U User_admin -d Centro_Tecnico_Electronico -c \"SELECT * FROM \\\"Tecnicos\\\";\""
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "multer": "^1.4.5-lts.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pdfkit": "^0.13.0",
    "pg": "^8.21.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prisma": "^5.22.0"
  },
  "keywords": [
    "express",
    "prisma",
    "postgresql",
    "backend",
    "electronic-service"
  ],
  "author": "CTE Dev Team",
  "license": "ISC"
}
