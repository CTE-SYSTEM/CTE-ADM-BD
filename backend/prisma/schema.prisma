generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// para logica de el sistema de perfiles y usuarios

model Usuarios {
  id_usuario         Int      @id @default(autoincrement())
  nombre_usuario     String   @unique
  contrasena_hash    String
  correo_electronico String?
  rol                String   // Admin, Jefe Tecnico, Tecnico, Recepcion
  activo             Boolean  @default(true)
  fecha_creacion     DateTime @default(now())
  tecnico            Tecnicos?

  @@map("Usuarios")
}

// --- CLIENTES Y EQUIPOS ---

model Clientes {
  id_cliente          Int       @id @default(autoincrement())
  nombre              String    
  telefono            String?   @unique
  direccion           String?   
  correo              String?   
  contacto_secundario String?   
  activo              Boolean   @default(true)
  equipos             Equipos[]


  @@map("Clientes")
}

model Equipos {
  id_equipo    Int           @id @default(autoincrement())
  cliente_id   Int
  marca        String?       
  tipo         String?       
  numero_serie String?       
  modelo       String?       
  cliente      Clientes      @relation(fields: [cliente_id], references: [id_cliente])
  diagnosticos Diagnosticos[]

  @@map("Equipos")
}

// --- FLUJO DE TRABAJO ---

model Tecnicos {
  id_tecnico   Int       @id @default(autoincrement())
  usuario_id   Int?      @unique
  usuario      Usuarios? @relation(fields: [usuario_id], references: [id_usuario], onDelete: Cascade)
  nombre       String    
  especialidad String?   // Ejemplo: Microelectrónica, Laptops, Celulares
  horario      String?   // Ejemplo: "Lunes a Viernes 08:00 - 17:00"
  contacto     String?   // Teléfono o medio de comunicación interno
  activo       Boolean   @default(true)

  diagnosticos Diagnosticos[]
  ordenes      Ordenes[]

  @@map("Tecnicos")
}

model Diagnosticos {
  id_diagnostico          Int       @id @default(autoincrement())
  equipo_id               Int
  tecnico_id              Int?      // Permite que sea nulo hasta asignar técnico
  falla_reportada         String?   
  diagnostico_real        String?  
  presupuesto_estimado    Decimal?  @db.Decimal(18, 2)
  prioridad               String?   @default("Normal") // Urgente - Alta - Normal
  fecha_hora              DateTime? @default(now())
  fecha_asignacion        DateTime?
  
  // Estados
  estado_del_diagnostico  String    @default("PENDIENTE") // PENDIENTE, EN_REVISION, COMPLETADO
  Estado_aprobacion       String    @default("Pendiente") // Pendiente, Aprobado, Rechazado 

  // Checks de Recepción
  deja_cargador           Boolean   @default(false)
  enciende                Boolean   @default(false)
  usa_corriente_ac        Boolean   @default(false)

  // Relaciones
  equipo                  Equipos   @relation(fields: [equipo_id], references: [id_equipo])
  tecnico                 Tecnicos? @relation(fields: [tecnico_id], references: [id_tecnico]) // Corregido: Tecnicos?
  ordenes                 Ordenes[]

  @@map("Diagnosticos")
}

model Ordenes {
  id_orden                Int       @id @default(autoincrement())
  diagnostico_id          Int
  tecnico_id              Int?      // Permite que sea nulo al inicio
  prioridad               String?   // Urgente - Alta - Normal
  estado                  String?   @default("PENDIENTE") // INGRESADO, REPARACION, FINALIZADO
  fecha_ingreso           DateTime? @default(now())
  resultado_final         String?
  enciende_salida         Boolean?
  usa_corriente_ac_salida Boolean?
  observacion_final       String?
  fecha_cierre            DateTime?
  
  // Relaciones
  diagnostico             Diagnosticos @relation(fields: [diagnostico_id], references: [id_diagnostico])
  tecnico                 Tecnicos?    @relation(fields: [tecnico_id], references: [id_tecnico]) // Corregido: Tecnicos?
  
  repuestos_usados        Ordenes_Repuestos[]
  facturas                Facturas[]

  @@map("Ordenes")
}

// --- REPUESTOS E INVENTARIO (BAJO PEDIDO) ---

model Categorias_Repuestos {
  id_tipo_repuesto Int                 @id @default(autoincrement())
  nombre_tipo      String?             
  electronico      String?             
  repuestos        Repuestos[]

  @@map("Categorias_Repuestos")
}

model Repuestos {
  id_repuesto       Int                  @id @default(autoincrement())
  tipo_repuesto_id  Int
  proveedor_id      Int?
  nombre            String?
  descripcion       String?
  costo_individual Decimal?             @db.Decimal(18, 2) // Se actualiza con la última compra se necesita un trigger
  porcentaje_de_ganacia     Decimal?             @db.Decimal(18, 2) // Campo legado: conservar para no perder datos existentes
  ganancia_cordobas Decimal?             @db.Decimal(18, 2)
  stock_actual     Int                  @default(0)
  activo           Boolean              @default(true) // Campo legado: conservar para compatibilidad con datos/scripts existentes
  descontinuada     Boolean              @default(false)

  categoria        Categorias_Repuestos @relation(fields: [tipo_repuesto_id], references: [id_tipo_repuesto])
  proveedor        Proveedores?         @relation(fields: [proveedor_id], references: [id_proveedor])
  compras          Compras[]
  ordenes_detalles Ordenes_Repuestos[]

  @@map("Repuestos")
}

model Ordenes_Repuestos {
  id_detalle_repuesto Int       @id @default(autoincrement())
  orden_id            Int
  repuesto_id         Int?
  pieza_solicitada    String?
  cantidad_usada      Int?      @default(1)
  
  // El Check de aprobación del Jefe Técnico 
  estado_aprobacion   String    @default("PENDIENTE") // PENDIENTE, APROBADO, DENEGADO
  
  orden               Ordenes   @relation(fields: [orden_id], references: [id_orden])
  repuesto            Repuestos? @relation(fields: [repuesto_id], references: [id_repuesto])

  @@map("Ordenes_Repuestos")
}

// --- COMPRAS Y PROVEEDORES ---

model Proveedores {
  id_proveedor Int       @id @default(autoincrement())
  nombre       String    
  telefono     String?   
  direccion    String?   
  correo       String?
  web          String?   
  notas        String?   // Para anotar horarios o si tienen buenos repuestos o si incluso hubo problemas con las piezas
  descontinuada    Boolean @default(true)
  repuestos    Repuestos[]
  compras      Compras[]

  @@map("Proveedores")
}

model Compras {
  id_compra        Int         @id @default(autoincrement())
  repuesto_id      Int
  proveedor_id     Int
  documento        String?     // Número de recibo o factura de la tienda
  fecha_obtencion  DateTime?   @default(now())
  cantidad         Int?
  costo_unitario   Decimal?    @db.Decimal(18, 2)
  metodo_pago      String?     // Efectivo, Transferencia
  
  proveedor        Proveedores @relation(fields: [proveedor_id], references: [id_proveedor])
  repuesto         Repuestos   @relation(fields: [repuesto_id], references: [id_repuesto])

  @@map("Compras")
}

// --- FACTURACIÓN Y POST-VENTA ---

model Facturas {
  id_factura    Int       @id @default(autoincrement())
  orden_id      Int       @unique
  fecha_emision DateTime? @default(now())
  monto_repuestos Decimal? @db.Decimal(18, 2) // La suma de lo que se uso
  mano_obra       Decimal? @db.Decimal(18, 2) // El costo del servicio técnico
  
  subtotal      Decimal?  @db.Decimal(18, 2) // monto repuestos + mano de obra
  impuestos     Decimal?  @db.Decimal(18, 2)
  total         Decimal?  @db.Decimal(18, 2)
  
  metodo_pago   String?   
  orden         Ordenes   @relation(fields: [orden_id], references: [id_orden])
  garantias     Garantias[]

  @@map("Facturas")
}

model Garantias {
  id_garantia       Int       @id @default(autoincrement())
  factura_id        Int       @unique
  condiciones       String?   
  duracion_meses    Int?
  fecha_inicio      DateTime? 
  fecha_vencimiento DateTime? 
  factura           Facturas  @relation(fields: [factura_id], references: [id_factura])

  @@map("Garantias")
}
